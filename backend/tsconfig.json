{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./app",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@/*": ["./app/*"],
      "@lib/*": ["./app/lib/*"],
      "@utils/*": ["./app/utils/*"],
      "@components/*": ["./app/components/*"]
    },
    "types": ["node", "vitest/globals"]
  },
  "include": ["app/**/*.ts"],
  "exclude": ["node_modules", "dist", "tests"]
}